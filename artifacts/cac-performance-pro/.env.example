
# ─────────────────────────────────────────────────────────────────────────────
# Store links — fill in the real values once CAC Performance PRO is published.
#
# App Store (iOS):
#   1. Open https://appstoreconnect.apple.com and find your app's Apple ID
#      (a 9-10 digit number, e.g. 1234567890).
#   2. Replace the value below:
# ─────────────────────────────────────────────────────────────────────────────
VITE_APP_STORE_URL=https://apps.apple.com/br/app/cac-performance-pro/id<YOUR_APPLE_ID>

# ─────────────────────────────────────────────────────────────────────────────
# Google Play (Android):
#   1. Open https://play.google.com/console and find your app's package name
#      (e.g. com.cacperformancepro).
#   2. Replace the value below:
# ─────────────────────────────────────────────────────────────────────────────
VITE_GOOGLE_PLAY_URL=https://play.google.com/store/apps/details?id=com.cacperformancepro

# ─────────────────────────────────────────────────────────────────────────────
# Set to "true" once both store listings are live to change the Download
# section badge from "Disponível Em Breve" (orange) to "Disponível Agora" (green).
# ─────────────────────────────────────────────────────────────────────────────
VITE_APP_LIVE=false
